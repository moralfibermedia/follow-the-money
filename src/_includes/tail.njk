<div class="promo">
  <h2 class="promo-h">Inspired by</h2>
  <div class="inspired">
  {%- for i in inspired %}
    <a class="ins" href="{{ i.url }}" target="_blank" rel="noopener">
      <span class="ins-n">{{ i.n }}</span>
      <span><span class="ins-t">{{ i.title }}</span><br><span class="ins-d">{{ i.desc }}</span><br><span class="ins-u">{{ i.host }}</span></span>
    </a>
  {%- endfor %}
  </div>

  <h2 class="promo-h">Pro-democracy fighters</h2>
  <p class="promo-sub">People and organizations on the front lines.</p>
  <div class="fighters">
  {%- for fgt in featuredFighters %}
    <a class="fgt" href="{{ fgt.url }}" target="_blank" rel="noopener">
      <span class="fgt-i">✊</span>
      <span><span class="fgt-n">{{ fgt.name }}</span><br><span class="fgt-d">{{ fgt.desc }}</span></span>
    </a>
  {%- endfor %}
  </div>
  <a class="fgt-all" href="/fighters">See the full list →</a>
</div>

<div class="tail">
  <div class="brandrow">
    <img class="brandmark" src="/assets/mfm-mark.png" alt="Moral Fiber Media — fist and megaphones mark" width="44" height="44" loading="lazy">
    <span class="brandname">Moral Fiber <em>Media</em><br><span class="brandtag">{{ site.tagline }}</span></span>
  </div>
  {% if license == "by-nc-sa" %}
  <div><span class="tag">License</span>This work is licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/3.0/us/" target="_blank" rel="noopener">CC BY-NC-SA 3.0</a> · attribution · non-commercial · share-alike</div>
  <div><span class="tag">Credit</span>Created by <a href="https://moralfibermedia.com" target="_blank" rel="noopener">Moral Fiber Media</a> · Data from <a href="https://www.opensecrets.org/open-data/credit-opensecrets" target="_blank" rel="noopener">OpenSecrets.org</a></div>
  {% else %}
  <div><span class="tag">License</span>This work is licensed under <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a> · original content by Moral Fiber Media</div>
  <div><span class="tag">Credit</span>Created by <a href="https://moralfibermedia.com" target="_blank" rel="noopener">Moral Fiber Media</a>{% if creditData %} · {{ creditData }}{% endif %}</div>
  {% endif %}
  <div><span class="tag">Follow</span><a href="https://www.youtube.com/@MoralFiberMedia" target="_blank" rel="noopener">YouTube</a> · <a href="https://www.tiktok.com/@moralfibermedia" target="_blank" rel="noopener">TikTok</a> · <a href="https://bsky.app/profile/moralfibermedia.bsky.social" target="_blank" rel="noopener">Bluesky</a> · <a href="https://sez.us/user/MoralFiberMedia" target="_blank" rel="noopener">Sez.us</a> · <a href="https://moralfibermedia.com" target="_blank" rel="noopener">Substack</a> · <a href="https://buymeacoffee.com/moralfibermedia" target="_blank" rel="noopener">Leave a tip ☕</a></div>
  <div><span class="tag">More</span><a href="/">All puzzles</a> · <a href="/fighters">Pro-democracy fighters</a> · <a href="/legal">Privacy &amp; terms</a></div>
</div>
