<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

<meta name="description" content="{{ pageDescription }}">
<link rel="canonical" href="{{ site.base }}{{ canonicalPath }}">

<meta property="og:type" content="website">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ pageDescription }}">
<meta property="og:url" content="{{ site.base }}{{ canonicalPath }}">
<meta property="og:image" content="{{ site.base }}{{ ogImage }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ pageTitle }}">
<meta name="twitter:description" content="{{ pageDescription }}">
<meta name="twitter:image" content="{{ site.base }}{{ ogImage }}">

<title>{{ pageTitle }}</title>
{% if jsonld %}<script type="application/ld+json">{{ jsonld | safe }}</script>{% endif %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,900&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/site.css">
{% if extraHead %}{{ extraHead | safe }}
{% endif %}</head>
<body>
<header class="site-band">
  <a class="band-brand" href="/">
    <img src="/assets/mfm-mark.png" alt="" width="34" height="34">
    <span>Follow the <em>Money</em></span>
  </a>
  <nav class="band-nav">
    <a href="/">Puzzles</a>
    <a href="/fighters">Fighters</a>
    <a href="https://moralfibermedia.com" target="_blank" rel="noopener">Substack</a>
  </nav>
</header>
<div class="article">
{% if pageScript %}
<div class="page-grid">
<div class="page-main">
{{ content | safe }}
</div>
{% include "rail.njk" %}
</div>
{% else %}
{{ content | safe }}
{% endif %}
{% include "tail.njk" %}
</div>
{% if pageScript %}<script src="{{ pageScript }}"></script>{% endif %}
</body>
</html>
