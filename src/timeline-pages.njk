---
layout: layouts/base.njk
pagination: { addAllPagesToCollections: true, data: timelines, size: 1, alias: p }
permalink: "/{{ p.path }}/index.html"
pageScript: /assets/reorder.js
eleventyComputed:
  pageTitle: "{{ p.title }} — Follow the Money | Moral Fiber Media"
  pageDescription: "{{ p.subtitle }}"
  canonicalPath: "/{{ p.path }}"
  ogImage: "/{{ p.path }}/preview.png"
  jsonld: "{{ p | puzzleJsonld | safe }}"
  license: "{{ 'by-nc-sa' if p.data_license == 'CC BY-NC-SA 3.0' else 'by' }}"
  creditData: "timeline from the public record; sourced per event below"
---
<div class="kicker"><a href="/">Follow the Money</a> · timeline puzzle</div>
<h1>{{ p.title | emLast | safe }}</h1>
<div class="standfirst">{{ p.subtitle }}</div>
<div class="meta">{{ p.direction }} &nbsp;·&nbsp; {{ p.events | length }} events · ~2 min</div>

{% if p.article_hook %}<p>{{ p.article_hook | safe }}</p>{% endif %}
<p>Five real events, dates hidden — that's the puzzle. Tap two cards to swap them, or use the arrows. Lock it in and the dates animate into place, every event linked to the record.</p>
<p>{{ p.hint | stripHint }}</p>

{% set figMechanic = "TIMELINE" %}
{% set figMeta = "Interactive · order " ~ (p.events | length) %}
{% set figCover = "/" ~ p.path ~ "/preview.png" %}
{% set figAlt = p.title ~ " — puzzle preview" %}
{% if p.number %}{% set figStamp = "Nº " ~ p.number %}{% else %}{% set figStamp = "★" %}{% endif %}
<div class="figure plate" id="fig">
  <span class="plate-stamp">{{ figStamp }}</span>
  <div class="plate-body">
  {% include "figure-plate.njk" %}
  <div class="fig-game">
    <div class="score-bar"><span>In order <b id="m">—</b>/{{ p.events | length }}</span></div>
    <div class="tray-label" id="tl"><span class="step-num" id="sn">1</span> <span id="tt">Tap a card, then tap where it goes</span></div>
    <div class="rlist timeline attention" id="rlist">
      {%- for e in p.events | byScramble(p.scramble) %}
      <div class="ritem" data-id="{{ e.id }}" data-rank="{{ e.rank }}" data-date="{{ e.date }}">
        <div class="rbadge">{{ ["1st","2nd","3rd","4th","5th","6th"][loop.index0] }}</div>
        <div class="rbody">
          <div class="rname">{{ e.title }}<span class="rmark"></span></div>
          <div class="rdesc">{{ e.description }}</div>
          <span class="chip"></span>
          <div class="rreveal">
            <div class="rsrc">{%- for s in e.sources %}<a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.label }}</a>{%- endfor %}</div>
          </div>
        </div>
        <div class="rmove">
          <button type="button" aria-label="Move {{ e.title }} earlier" onclick="moveItem(this,-1,event)">▲</button>
          <button type="button" aria-label="Move {{ e.title }} later" onclick="moveItem(this,1,event)">▼</button>
        </div>
      </div>
      {%- endfor %}
    </div>
    <div class="lockrow"><button class="start-btn" type="button" id="lockb" onclick="lockIn()">Lock it in</button></div>
    <div class="doneb" id="doneb">
      <div class="rank" id="rank"><span id="rankLabel">Perfect</span><span class="stars" id="stars">★★★</span></div>
      <p>The true chronology is above — every date in the public record.</p>
      <button class="start-btn again" type="button" onclick="resetPuzzle()">↺ Play again</button>
      <button class="start-btn again" type="button" id="shareb" onclick="sharePuzzle()">📤 Share</button>
    </div>
  </div>
  </div>
</div>
<div class="fig-caption">Hint: {{ p.hint | stripHint }}</div>

<h2>The receipts</h2>
<p>Every date, sourced{% if p.id == "under-new-management" %} three ways — gov/SEC filing, company announcement, independent coverage. Check any of them; check all of them{% endif %}:</p>
<div class="receipts"><ul>
  {%- for e in p.events %}
  <li><span>{{ e.title }}</span>
    <span class="receipt-srcs">
    {%- for s in e.sources %}
      <a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.label }} ↗</a>
    {%- endfor %}
    </span></li>
  {%- endfor %}
</ul></div>

<script>window.__PUZZLE = { mode: "timeline", total: {{ p.events | length }}, thresholds: [{{ p.events | length }}, 3] };</script>
